// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Clinic {
  id      String  @id @default(uuid())
  name    String
  address String?
  phone   String?

  lastEditedById String?
  lastEditedBy   User?   @relation("ClinicLastEditor", fields: [lastEditedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
}

enum UserRole {
  ADMIN
  DOCTOR
  ASSISTANT
}

enum Sex {
  MALE
  FEMALE
}

model User {
  id         String   @id @default(uuid())
  firstName  String
  middleName String
  lastName   String
  username   String   @unique
  password   String
  role       UserRole
  licenseNum String?

  isActive Boolean @default(true)

  patientsLastEdited Patient[] @relation("PatientLastEditor")
  clinicsLastEdited  Clinic[]  @relation("ClinicLastEditor")
  recordsLastEdited  Record[]  @relation("RecordLastEditor")

  createdRecords Record[] @relation("RecordCreator")

  cases Case[]

  createdAt  DateTime     @default(now())
  records    Record[]
  systemLogs SystemLogs[]
  clinics    Clinic[]
}

model Patient {
  id          String   @id @default(uuid())
  firstName   String
  middleName  String
  lastName    String
  phone       String   @unique
  address     String
  sex         Sex
  dateOfBirth DateTime

  isArchived Boolean   @default(false)
  archivedOn DateTime?

  cases   Case[]
  records Record[]

  lastEditedById String?
  lastEditedBy   User?   @relation("PatientLastEditor", fields: [lastEditedById], references: [id])

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @default(now()) @updatedAt
  labResults labResult[]
}

model Case {
  id        String @id @default(uuid())
  caseName  String
  patientId String

  records Record[]

  doctorId String?
  doctor   User?   @relation(fields: [doctorId], references: [id])

  patient Patient @relation(fields: [patientId], references: [id])
}

model Record {
  id        String   @id @default(uuid())
  patientId String
  visitDate DateTime @default(now())

  isArchived Boolean   @default(false)
  archivedOn DateTime?

  symptoms  String?
  signs     String?
  diagnosis String?

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @default(now()) @updatedAt
  vitalSigns        VitalSigns?
  recordMedications RecordMedication[]

  caseId String
  case   Case    @relation(fields: [caseId], references: [id])
  user   User?   @relation(fields: [userId], references: [id])
  userId String?

  lastEditedById String?
  lastEditedBy   User?   @relation("RecordLastEditor", fields: [lastEditedById], references: [id])

  createdById String
  createdBy   User   @relation("RecordCreator", fields: [createdById], references: [id])
}

model VitalSigns {
  id       String @id @default(uuid())
  recordId String @unique
  record   Record @relation(fields: [recordId], references: [id], onDelete: Cascade)

  bloodPressureSystolic  Int?
  bloodPressureDiastolic Int?

  temperature Decimal? @db.Decimal(4, 1)
  weightKg    Decimal? @db.Decimal(5, 2)
}

model RecordMedication {
  id       String @id @default(uuid())
  record   Record @relation(fields: [recordId], references: [id], onDelete: Cascade)
  recordId String

  name         String
  dosage       String
  frequency    String
  durationDays Int?
  instructions String?

  createdAt DateTime @default(now())
}

model labResult {
  id         String   @id @default(uuid())
  patient    Patient  @relation(fields: [patientId], references: [id])
  patientId  String
  filePath   String
  uploadedAt DateTime @default(now())
}

model GoogleToken {
  id           Int      @id @default(autoincrement())
  refreshToken String
  email        String?
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SystemLogs {
  id String @id @default(uuid())

  action  String
  module  String
  target  String
  details String

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}
